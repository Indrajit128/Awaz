// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  fcmToken      String?
  walletBalance Float     @default(0.0)
  accounts      Account[]
  sessions      Session[]
  callsAsCaller Call[]    @relation("Caller")
  callsAsCallee Call[]    @relation("Callee")
  transactions  Transaction[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Call {
  id        String   @id @default(cuid())
  callerId  String
  calleeId  String
  startTime DateTime @default(now())
  endTime   DateTime?
  duration  Int?     // duration in seconds
  cost      Float?   // cost in rupees
  status    String   // COMPLETED, MISSED, REJECTED

  caller    User     @relation("Caller", fields: [callerId], references: [id])
  callee    User     @relation("Callee", fields: [calleeId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  type      String   // CREDIT (recharge), DEBIT (call cost)
  source    String   // RAZORPAY, CALL_SYSTEM
  metadata  String?    // Store razorpay_payment_id etc. as JSON string
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
