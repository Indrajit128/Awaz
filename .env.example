# ─── DATABASE URL ──────────────────────────────────────────
# Generated by Prisma. Local Prisma Postgres example:
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# ─── NEXTAUTH (Authentication) ─────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-development-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Credentials:
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── ZEGOCLOUD (Voice Calls) ──────────────────────────────
# Obtain these from ZegoCloud Admin Console
NEXT_PUBLIC_ZEGO_APP_ID="your-zego-app-id"
NEXT_PUBLIC_ZEGO_SERVER_SECRET="your-zego-server-secret"

# ─── FIREBASE (Push Notifications) ────────────────────────
# Required for sending notifications from the backend
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"

# ─── RAZORPAY (Payments/Wallet) ───────────────────────────
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
